  - _profile: {fileID: -1996703693659354134, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Zoe
    _sentences: 'That just means I get two setbacks to deliver.

      It would''ve
      been boring only smashing robots.'
