  line:
  - _profile: {fileID: -3668614178636754847, guid: c507d03ae229e6f44a2202f3f48cbdce,
      type: 3}
    _cutscene: {fileID: 21300000, guid: 42b1c1f033041aa4bbdefa401205afef, type: 3}
    _name: Bomber
    _sentences: You got some nerve bumping into me.
  - _profile: {fileID: -1996703693659354134, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 21300000, guid: 42b1c1f033041aa4bbdefa401205afef, type: 3}
    _name: Zoe
    _sentences: "You think you\u2019re scary? I\u2019ve had worse customers.\nGet
      lost already."
  - _profile: {fileID: -3668614178636754847, guid: c507d03ae229e6f44a2202f3f48cbdce,
      type: 3}
    _cutscene: {fileID: 21300000, guid: 42b1c1f033041aa4bbdefa401205afef, type: 3}
    _name: Bomber
    _sentences: "Then you won\u2019t mind dealing with my rough customers right?
      I\u2019ve got places to blow anyway."
  - _profile: {fileID: -1996703693659354134, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 21300000, guid: 42b1c1f033041aa4bbdefa401205afef, type: 3}
    _name: Zoe
    _sentences: "Oh you\u2019ll get yours soon enough coward!"
