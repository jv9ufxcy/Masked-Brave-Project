  line:
  - _profile: {fileID: 1976531482833533092, guid: d4263f85349f25f44909748074bb120e,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Zoe
    _sentences: "As fun as it was to fight your militia,\r\nI need you to hand over
      that device.\r"
  - _profile: {fileID: 3292930165984601596, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Kid
    _sentences: "Boo, fun police.\r\nI paid fair and square, so buzz off.\r"
  - _profile: {fileID: -1996703693659354134, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Zoe
    _sentences: "Be serious about this kid.\r\nSomeone could've gotten hurt.\r"
  - _profile: {fileID: 3292930165984601596, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Kid
    _sentences: 'Like I don''t know what I''m doing?

      I''m gonna put the hurt
      on you instead.

'
  - _profile: {fileID: -1996703693659354134, guid: f0120b5629f3f4449a7fe99b64f1ab92,
      type: 3}
    _cutscene: {fileID: 0}
    _name: Zoe
    _sentences: "So hostile, guess I've got no choice.\r\nBring it on.\r"
